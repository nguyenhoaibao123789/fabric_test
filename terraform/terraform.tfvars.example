workspace_id   = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # Fabric workspace GUID from portal URL
spark_env_name = "dev-spark-env"                          # Display name for the Spark Environment item

# Git sync for Airflow DAGs
git_repo_url    = "https://github.com/your-org/your-repo"
git_branch      = "main"
git_dags_folder = "fabric/dags"

# GitHub PAT — repo:read scope is sufficient for a private repo
# Generate at: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
github_pat = "ghp_xxxxxxxxxxxxxxxxxxxx"
